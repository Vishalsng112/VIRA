    "from mss import MSS\n",
    "\n",
    "# The simplest use, save a screenshot of the 1st monitor\n",
    "with MSS() as sct:\n",
    "    image = sct.shot()\n",
    "    #  save the image to a file\n",
    "    print(f\"Screenshot saved to: {image}\")\n",
    "    \n",
    "\n"
   ]
